# EditorConfig helps keep coding styles consistent across editors and IDEs.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

# Python conventionally uses 4 spaces
[*.py]
indent_size = 4

# Go uses tabs
[*.go]
indent_style = tab

# Makefiles require real tabs
[{Makefile,makefile,*.mk}]
indent_style = tab

# Don't enforce whitespace rules on Markdown (trailing spaces = line breaks)
[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml,json}]
indent_size = 2
